datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?  // Added for user profile
  passwordHash  String
  preferences   String   @default("[]") // JSON string of themes like ["Technology", "Marketing"]
  createdAt     DateTime @default(now())
  posts         Post[]
}

model Post {
  id          String   @id @default(uuid())
  userId      String
  theme       String
  hook        String
  content     String
  imagePrompt String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
